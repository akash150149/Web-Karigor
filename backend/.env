PORT=5000
NODE_ENV=development

# ── Email (SMTP) ──────────────────────────────────────────────────
# Gmail example: set SMTP_HOST=smtp.gmail.com, SMTP_USER=you@gmail.com
#   and SMTP_PASS to your Gmail "App Password" (16 chars, no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=Web-Karigor <your@gmail.com>
TEAM_EMAIL=team@web-karigor.com

# ── Slack Incoming Webhook ────────────────────────────────────────
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ── Discord Webhook (alternative to Slack) ───────────────────────
# Create in Discord channel settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# ── Booking Config ───────────────────────────────────────────────
MAX_BOOKINGS_PER_DAY=6










